# ─────────────────────────────────────────────────────────────────────────────
# EliteFlow Nebula v2 — environment template
# Copy to .env (the installer does this for you) and fill in the blanks.
# Never commit the real .env. Never bake the API key into an image.
# ─────────────────────────────────────────────────────────────────────────────

# Instance identity
PROJECT_NAME=EliteFlow Nebula
TIMEZONE=Asia/Bangkok

# App secret — signs dashboard sessions AND encrypts the stored Claude credential.
# The installer generates a random value. Keep it stable: rotating it invalidates the
# operator session and makes the stored credential undecryptable (re-Connect required).
APP_SECRET=

# Postgres
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentflow
POSTGRES_PORT=5432
# Connection string used by the app services (host is the compose service name)
DATABASE_URL=postgres://agentflow:change-me@postgres:5432/agentflow

# Claude Code auth (headless). Provide EXACTLY ONE of the following.
#  • CLAUDE_CODE_OAUTH_TOKEN — uses your Claude Pro/Max subscription. Mint it once with
#    `claude setup-token` (that one command IS the browser login). Preferred: no per-token bill.
#  • ANTHROPIC_API_KEY — Anthropic Console key, billed per token.
# The container cannot do the interactive browser popup, so the credential is supplied here.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
# Guard: the orchestrator warns at startup if ANTHROPIC_API_KEY is set (it is metered).
# Set OAUTH_ONLY=true to make that a hard refusal — guarantees subscription-only billing.
OAUTH_ONLY=
# Model the persona workers run on
CLAUDE_MODEL=claude-opus-4-8

# Workspace mounted into the orchestrator (instruction/, persona/, database/ CSVs).
# Sibling of app/ in the eliteflow-nebula folder. The installer resolves it to absolute.
WORKSPACE_PATH=../workspace
# The product repo the personas generate/edit (sibling `product/` folder).
SOURCE_REPO_PATH=../product

# Web UI
WEB_PORT=3000

# Orchestrator
# Cron expression for firing work-cycles (default: every 30 min). Empty = on-demand only.
CYCLE_CRON=*/30 * * * *
# Max persona invocations per cycle (cost guard)
MAX_RUNS_PER_CYCLE=12
